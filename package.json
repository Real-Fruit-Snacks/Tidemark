{
  "name": "tidemark",
  "displayName": "Tidemark",
  "description": "Replace variables in markdown with YAML frontmatter values on demand. Perfect for pentesting notes, CTF templates, and reusable note structures.",
  "version": "1.0.6",
  "publisher": "Real-Fruit-Snacks",
  "author": "Real-Fruit-Snacks",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src --ext ts",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "esbuild": "^0.24.0",
    "eslint": "^8.56.0",
    "obsidian": "1.12.3",
    "tslib": "^2.7.0",
    "typescript": "^5.3.3",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@codemirror/view": "*",
    "@codemirror/state": "*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/real-fruit-snacks/tidemark"
  },
  "bugs": {
    "url": "https://github.com/real-fruit-snacks/tidemark/issues"
  },
  "license": "MIT"
}
