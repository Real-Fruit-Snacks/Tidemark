    "builtin-modules": "^4.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^8.56.0",
    "obsidian": "latest",
    "tslib": "^2.7.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "repository": {
    "type": "git",
